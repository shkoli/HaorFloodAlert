# HaorFloodAlert — environment variables
# Copy this file to .env and fill in your values.
# Never commit your real .env to version control.

# Google Earth Engine project ID
# Create a project at: https://code.earthengine.google.com/
GEE_PROJECT=your-gee-project-id

# Gmail SMTP alert credentials
# Generate an App Password at: myaccount.google.com/apppasswords
# (Requires 2-Step Verification enabled on the sender account)
ALERT_EMAIL_SENDER=your_gmail@gmail.com
ALERT_EMAIL_RECIPIENT=recipient@example.com
ALERT_APP_PASSWORD=xxxx xxxx xxxx xxxx
